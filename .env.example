# ============================================================================
# .env.example — aumos-fairness-suite
# Copy to .env and fill in values for local development.
# All variables use the AUMOS_FAIRNESS_ prefix (repo-specific settings)
# or the AUMOS_ prefix (inherited from aumos-common base settings).
# ============================================================================

# --- Service identity ---
AUMOS_SERVICE_NAME=aumos-fairness-suite
AUMOS_LOG_LEVEL=info

# --- Database (PostgreSQL via asyncpg) ---
AUMOS_FAIRNESS_DATABASE__URL=postgresql+asyncpg://aumos:aumos@localhost:5432/aumos_fairness

# --- Kafka ---
AUMOS_FAIRNESS_KAFKA__BOOTSTRAP_SERVERS=localhost:9092
AUMOS_FAIRNESS_KAFKA__SECURITY_PROTOCOL=PLAINTEXT

# --- Fairness thresholds ---
# Disparate impact ratio (4/5 rule): pass if >= this value
AUMOS_FAIRNESS_DISPARATE_IMPACT_THRESHOLD=0.8
# Absolute difference metrics: pass if abs(value) <= this value
AUMOS_FAIRNESS_PARITY_DIFFERENCE_THRESHOLD=0.1
# Synthetic data amplification: pass if amplification factor <= this value
AUMOS_FAIRNESS_AMPLIFICATION_THRESHOLD=1.2
# KL divergence for distribution shift in synthetic data
AUMOS_FAIRNESS_KL_DIVERGENCE_THRESHOLD=0.05

# --- Upstream service URLs ---
AUMOS_FAIRNESS_GOVERNANCE_ENGINE_URL=http://localhost:8016
AUMOS_FAIRNESS_MLOPS_URL=http://localhost:8008

# --- Monitor scheduling ---
# Default cron expression for continuous monitors (every 6 hours)
AUMOS_FAIRNESS_DEFAULT_MONITOR_CRON=0 */6 * * *
# How many past predictions to use for monitoring assessments
AUMOS_FAIRNESS_MONITOR_WINDOW_SIZE=10000

# --- Report settings ---
# Regulatory frameworks to include in reports by default (comma-separated)
AUMOS_FAIRNESS_DEFAULT_REPORT_FRAMEWORKS=ECOA,EU_AI_ACT
